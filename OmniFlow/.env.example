# ============================================
# OmniFlow — Environment Configuration
# ============================================

# ── General ──────────────────────────────────
NODE_ENV=development
PORT=4000
FRONTEND_URL=http://localhost:3000
API_URL=http://localhost:4000

# ── Database (PostgreSQL) ────────────────────
DATABASE_URL=postgresql://omniflow:omniflow_secret@localhost:5432/omniflow_dev
POSTGRES_USER=omniflow
POSTGRES_PASSWORD=omniflow_secret
POSTGRES_DB=omniflow_dev
POSTGRES_PORT=5432

# ── Redis ────────────────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379

# ── NATS (Event Bus) ────────────────────────
NATS_URL=nats://localhost:4222

# ── Meilisearch ──────────────────────────────
MEILI_URL=http://localhost:7700
MEILI_MASTER_KEY=omniflow_meili_master_key

# ── MinIO (S3-compatible Object Storage) ─────
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=omniflow_minio
MINIO_SECRET_KEY=omniflow_minio_secret
MINIO_BUCKET=omniflow-uploads
MINIO_USE_SSL=false

# ── Auth.js ──────────────────────────────────
AUTH_SECRET=change_me_to_a_random_64_char_string
AUTH_URL=http://localhost:3000
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=change_me_to_a_random_64_char_string

# ── OAuth Providers (fill when ready) ────────
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
# MICROSOFT_CLIENT_ID=
# MICROSOFT_CLIENT_SECRET=

# ── JWT ──────────────────────────────────────
JWT_SECRET=change_me_to_a_random_jwt_secret
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# ── Email (SMTP) ─────────────────────────────
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_FROM=noreply@omniflow.dev
